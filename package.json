{
	"name": "paymesh",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --filter @paymesh/web dev",
		"build": "bun run build:packages && bun run --filter @paymesh/web build",
		"build:packages": "bun run --filter './packages/*' build",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"typecheck": "bun run typecheck:packages",
		"typecheck:packages": "bun run --filter './packages/{paymesh,audit-logs,memory,postgres,drizzle,prisma,stripe,polar,abacatepay,dodo,express,fastify,hono,elysia,next,cli,mcp}' typecheck",
		"typecheck:apps": "bun run --filter './apps/*' typecheck",
		"types": "bun run typecheck",
		"test": "bun test --pass-with-no-tests",
		"clean": "rm -rf apps/web/.next packages/*/dist coverage",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run build:packages && changeset publish",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"@types/bun": "latest",
		"lefthook": "^2.1.8",
		"tsdown": "0.16.0",
		"typescript": "^5.9.3"
	}
}
