{
	"name": "@paymesh/mcp",
	"version": "0.0.0",
	"description": "Official MCP package for Paymesh.",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"bin": {
		"paymesh-mcp": "./dist/cli.mjs"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"paymesh": ">=0.0.0"
	},
	"devDependencies": {
		"paymesh": "workspace:*"
	},
	"dependencies": {
		"@cfworker/json-schema": "^4.1.1",
		"@modelcontextprotocol/server": "^2.0.0-alpha.2",
		"commander": "^14.0.2",
		"jiti": "^2.7.0",
		"zod": "^4.4.3"
	}
}
