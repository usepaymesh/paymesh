{
	"name": "@paymesh/cli",
	"version": "0.0.0",
	"description": "CLI for Paymesh database migrations, catalog sync, and status checks.",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"bin": {
		"paymesh": "./dist/cli.mjs"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.2",
		"picocolors": "^1.1.1"
	},
	"peerDependencies": {
		"paymesh": ">=0.0.0"
	},
	"devDependencies": {
		"paymesh": "workspace:*"
	}
}
