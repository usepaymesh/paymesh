{
	"name": "paymesh",
	"version": "0.0.0",
	"description": "Provider-agnostic payments toolkit for TypeScript applications.",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./stripe": {
			"import": {
				"types": "./dist/stripe.d.mts",
				"default": "./dist/stripe.mjs"
			},
			"require": {
				"types": "./dist/stripe.d.cts",
				"default": "./dist/stripe.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit"
	}
}
