{
	"name": "@paymesh/elysia",
	"version": "0.0.0",
	"description": "Elysia webhook adapter for Paymesh.",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"elysia": ">=1",
		"paymesh": ">=0.0.0"
	},
	"devDependencies": {
		"@paymesh/stripe": "workspace:*",
		"elysia": "^1.4.28",
		"paymesh": "workspace:*"
	}
}
